                                <td class="p-4 text-white/65">Adapta&ccedil;&otilde;es necess&aacute;rias, prazo incerto</td>
                            </tr>
                            <tr class="bg-white/[0.03]">
                                <td class="p-4 font-medium text-white">Prontid&atilde;o EHDS</td>
                                <td class="p-4 text-white/65">Preparado para troca de dados europeia</td>

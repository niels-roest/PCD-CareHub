                            </tr>
                            <tr class="bg-gray-50">
                                <td class="p-4 font-medium text-navy-900">Innovatiesnelheid</td>
                                <td class="p-4 text-gray-600">Best-of-breed, snelle adoptie van nieuwe tools</td>
                                <td class="p-4 text-gray-600">Afhankelijk van &eacute;&eacute;n roadmap</td>
                            </tr>
                            <tr class="bg-white">
                                <td class="p-4 font-medium text-navy-900">Wegiz-compliance</td>
                                <td class="p-4 text-gray-600">Van nature compliant</td>
                                <td class="p-4 text-gray-600">Aanpassingen nodig, onzeker tijdpad</td>
                            </tr>
                            <tr class="bg-gray-50">
                                <td class="p-4 font-medium text-navy-900">EHDS-gereedheid</td>
                                <td class="p-4 text-gray-600">Voorbereid op Europese data-uitwisseling</td>
                                <td class="p-4 text-gray-600">Risico op incompatibiliteit</td>
                            </tr>
                            <tr class="bg-white">
                                <td class="p-4 font-medium text-navy-900">Totale kosten (5 jaar)</td>
                                <td class="p-4 text-gray-600">Lagere TCO door concurrentie en hergebruik</td>
                                <td class="p-4 text-gray-600">20-40% hogere TCO door afhankelijkheid</td>
                            </tr>

        <section class="py-16 lg:py-20 bg-white" aria-label="Comparison of open standards versus vendor lock-in">
            <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-2xl sm:text-3xl font-bold text-navy-900 mb-8">Comparison: open standards vs vendor lock-in</h2>

                <div class="overflow-x-auto rounded-2xl border border-gray-200 shadow-sm mb-10">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="bg-navy-900 text-white">

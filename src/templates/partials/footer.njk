<!-- ============================================ -->
<!-- FOOTER                                       -->
<!-- ============================================ -->
<footer class="relative overflow-hidden" role="contentinfo">
    <!-- Thin aurora accent line on top -->
    <div aria-hidden="true" class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent-violet/60 to-transparent"></div>
    <!-- Soft decorative orb in lower-right -->
    <div aria-hidden="true" class="orb orb-violet -bottom-40 -right-20 h-[400px] w-[400px] opacity-[0.12]"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-10">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
            <!-- Column 1: Brand -->
            <div>
                <a href="{{ langPrefix }}/" class="inline-block mb-6" aria-label="{{ t.a11y.logo_aria }}">
                    <img src="{{ rootPath }}assets/logo/pcd-logo.webp" alt="{{ t.a11y.logo_alt }}" class="h-8 w-auto" width="160" height="40">
                </a>
                <p class="text-sm text-white/60 leading-relaxed mb-6 max-w-xs">{{ t.footer.description }}</p>
                <a href="https://www.linkedin.com/company/pcdcarehub" target="_blank" rel="noopener noreferrer" class="group inline-flex items-center gap-3 text-sm text-white/70 hover:text-white transition-colors" aria-label="PCD CareHub LinkedIn">
                    <span class="flex-shrink-0 w-9 h-9 rounded-full border border-white/10 bg-white/[0.04] flex items-center justify-center transition-all duration-300 group-hover:border-white/25 group-hover:bg-gradient-to-br group-hover:from-[#046bd2]/30 group-hover:to-[#7c3aed]/30">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    </span>
                    {{ t.footer.follow_linkedin }}
                </a>
            </div>

            <!-- Column 2: Ecosysteem -->
            <div>
                <h3 class="inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-white/50 mb-5">
                    <span aria-hidden="true" class="w-1 h-1 rounded-full bg-gradient-to-r from-[#60a5fa] to-[#a78bfa]"></span>
                    {{ t.footer.col_ecosystem }}
                </h3>
                <ul class="space-y-0">
                    <li><a href="{{ langPrefix }}/carehub-zorg-digitalisering" class="group inline-flex items-center gap-2 py-2 text-sm text-white/60 hover:text-white transition-colors"><span class="w-0 group-hover:w-3 h-px bg-brand-blue-light transition-all duration-200"></span>{{ t.nav.ecosystem_carehub }}</a></li>
                    <li><a href="{{ langPrefix }}/zorgorganisaties" class="group inline-flex items-center gap-2 py-2 text-sm text-white/60 hover:text-white transition-colors"><span class="w-0 group-hover:w-3 h-px bg-brand-blue-light transition-all duration-200"></span>{{ t.nav.ecosystem_zorgorganisaties }}</a></li>
                    <li><a href="{{ langPrefix }}/zorgtech-softwarebedrijven" class="group inline-flex items-center gap-2 py-2 text-sm text-white/60 hover:text-white transition-colors"><span class="w-0 group-hover:w-3 h-px bg-brand-blue-light transition-all duration-200"></span>{{ t.nav.ecosystem_zorgtech }}</a></li>
                    <li><a href="{{ langPrefix }}/investeerders-partners" class="group inline-flex items-center gap-2 py-2 text-sm text-white/60 hover:text-white transition-colors"><span class="w-0 group-hover:w-3 h-px bg-brand-blue-light transition-all duration-200"></span>{{ t.nav.ecosystem_investeerders }}</a></li>
                </ul>
            </div>

            <!-- Column 3: Over PCD -->
            <div>
                <h3 class="inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-white/50 mb-5">
                    <span aria-hidden="true" class="w-1 h-1 rounded-full bg-gradient-to-r from-[#a78bfa] to-[#f472b6]"></span>
                    {{ t.footer.col_about }}
                </h3>
                <ul class="space-y-0">
                    <li><a href="{{ langPrefix }}/pioneering-health-care-technology" class="group inline-flex items-center gap-2 py-2 text-sm text-white/60 hover:text-white transition-colors"><span class="w-0 group-hover:w-3 h-px bg-brand-blue-light transition-all duration-200"></span>{{ t.nav.about_pioneering }}</a></li>
                    <li><a href="{{ langPrefix }}/leiderschap" class="group inline-flex items-center gap-2 py-2 text-sm text-white/60 hover:text-white transition-colors"><span class="w-0 group-hover:w-3 h-px bg-brand-blue-light transition-all duration-200"></span>{{ t.nav.about_leadership }}</a></li>
                    <li><a href="{{ langPrefix }}/esg-verklaring" class="group inline-flex items-center gap-2 py-2 text-sm text-white/60 hover:text-white transition-colors"><span class="w-0 group-hover:w-3 h-px bg-brand-blue-light transition-all duration-200"></span>{{ t.nav.about_esg }}</a></li>
                    <li><a href="{{ langPrefix }}/strategie" class="group inline-flex items-center gap-2 py-2 text-sm text-white/60 hover:text-white transition-colors"><span class="w-0 group-hover:w-3 h-px bg-brand-blue-light transition-all duration-200"></span>{{ t.footer.strategy }}</a></li>
                </ul>
            </div>

            <!-- Column 4: Kennis & Contact -->
            <div>
                <h3 class="inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-white/50 mb-5">
                    <span aria-hidden="true" class="w-1 h-1 rounded-full bg-gradient-to-r from-[#60a5fa] to-[#f472b6]"></span>
                    {{ t.footer.col_contact }}
                </h3>
                <ul class="space-y-0">
                    <li><a href="{{ langPrefix }}/cases" class="group inline-flex items-center gap-2 py-2 text-sm text-white/60 hover:text-white transition-colors"><span class="w-0 group-hover:w-3 h-px bg-brand-blue-light transition-all duration-200"></span>{{ t.nav.cases }}</a></li>
                    <li><a href="{{ langPrefix }}/insights" class="group inline-flex items-center gap-2 py-2 text-sm text-white/60 hover:text-white transition-colors"><span class="w-0 group-hover:w-3 h-px bg-brand-blue-light transition-all duration-200"></span>{{ t.nav.insights }}</a></li>
                    <li><a href="{{ langPrefix }}/woordenlijst" class="group inline-flex items-center gap-2 py-2 text-sm text-white/60 hover:text-white transition-colors"><span class="w-0 group-hover:w-3 h-px bg-brand-blue-light transition-all duration-200"></span>{{ t.footer.glossary }}</a></li>
                </ul>
                <address class="not-italic space-y-2.5 text-sm text-white/60 mt-6">
                    <p class="flex items-start gap-2">
                        <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        <span>{{ t.footer.address | safe }}</span>
                    </p>
                    <p class="flex items-center gap-2">
                        <svg class="w-4 h-4 flex-shrink-0 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                        <a id="footer-email" href="#" class="hover:text-white transition-colors" data-u="info" data-d="pcdinvestmentpartners.com"></a>
                        <noscript><span>&#105;&#110;&#102;&#111;&#64;&#112;&#99;&#100;&#105;&#110;&#118;&#101;&#115;&#116;&#109;&#101;&#110;&#116;&#112;&#97;&#114;&#116;&#110;&#101;&#114;&#115;&#46;&#99;&#111;&#109;</span></noscript>
                    </p>
                    <p class="flex items-center gap-2">
                        <svg class="w-4 h-4 flex-shrink-0 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                        <a href="tel:+31653852753" class="hover:text-white transition-colors">+31 6 53 85 27 53</a>
                    </p>
                </address>
            </div>
        </div>

        <!-- Footer bottom -->
        <div class="mt-14 pt-6 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4">
            <p class="text-xs text-white/40">
                <span class="gradient-text font-medium">PCD CareHub</span> &middot; {{ t.footer.copyright | safe }} &middot; KvK 97139572
            </p>
            <div class="flex gap-6">
                <a href="{{ langPrefix }}/privacyverklaring" class="py-2 text-xs text-white/40 hover:text-white transition-colors">{{ t.footer.privacy }}</a>
                <a href="{{ langPrefix }}/cookiebeleid-eu" class="py-2 text-xs text-white/40 hover:text-white transition-colors">{{ t.footer.cookies }}</a>
                <a href="{{ langPrefix }}/algemene-voorwaarden" class="py-2 text-xs text-white/40 hover:text-white transition-colors">{{ t.footer.terms }}</a>
            </div>
        </div>
    </div>
</footer>

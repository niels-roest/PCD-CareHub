<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="referrer" content="strict-origin-when-cross-origin">
<meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline'; img-src 'self' https: data:; font-src 'self'; connect-src 'self' https://www.google-analytics.com https://region1.google-analytics.com;">
<title>{{ title }}</title>
<meta name="description" content="{{ description }}">
<meta name="author" content="PCD CareHub">
{% if noindex %}<meta name="robots" content="noindex, nofollow">{% else %}<meta name="robots" content="index, follow">{% endif %}
<link rel="canonical" href="{{ canonical }}">

<!-- Hreflang tags -->
{% for altLang in availableLanguages %}
<link rel="alternate" hreflang="{{ altLang.hreflang }}" href="{{ altLang.url }}">
{% endfor %}
<link rel="alternate" hreflang="x-default" href="{{ availableLanguages[0].url }}">

{% if lang == 'nl' %}
<!-- Auto language detection: redirect first-time visitors to their browser language -->
<script>
(function(){
  try {
    var h = location.hostname;
    if (h === 'localhost' || h === '127.0.0.1' || h.endsWith('.local') || /^\d+\.\d+\.\d+\.\d+$/.test(h)) return;
    if (localStorage.getItem('pcd-lang-choice')) return;
    if (sessionStorage.getItem('pcd-lang-redirected')) return;
    var bl = (navigator.language || navigator.languages && navigator.languages[0] || '').toLowerCase();
    var target = null;
    if (bl.indexOf('pt') === 0) target = 'pt-BR';
    else if (bl.indexOf('es') === 0) target = 'es';
    else if (bl.indexOf('en') === 0) target = 'en';
    if (!target) return;
    var link = document.querySelector('link[hreflang="' + target + '"]');
    if (link && link.href) {
      sessionStorage.setItem('pcd-lang-redirected', '1');
      window.location.replace(link.href);
    }
  } catch(e) {}
})();
</script>
{% endif %}

<!-- Open Graph -->
<meta property="og:type" content="{{ og_type or 'website' }}">
<meta property="og:title" content="{{ title }}">
<meta property="og:description" content="{{ description }}">
<meta property="og:url" content="{{ canonical }}">
<meta property="og:image" content="{{ og_image }}">
<meta property="og:site_name" content="PCD CareHub">
<meta property="og:locale" content="{{ og_locale }}">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ title }}">
<meta name="twitter:description" content="{{ description }}">
<meta name="twitter:image" content="{{ og_image }}">

<!-- Favicon -->
<link rel="icon" type="image/x-icon" href="{{ rootPath }}assets/favicon/favicon.ico">
<link rel="apple-touch-icon" sizes="180x180" href="{{ rootPath }}assets/favicon/apple-touch-icon.png">
<link rel="icon" type="image/png" sizes="32x32" href="{{ rootPath }}assets/favicon/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="{{ rootPath }}assets/favicon/favicon-16x16.png">

<!-- Preload critical resources -->
<link rel="preload" href="{{ rootPath }}assets/logo/pcd-logo.webp" as="image" type="image/webp">
<link rel="preload" href="{{ rootPath }}assets/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin>

<!-- Self-hosted Inter font -->
<style>
@font-face {
    font-family: 'Inter';
    font-style: normal;
    font-weight: 400 700;
    font-display: swap;
    src: url('{{ rootPath }}assets/fonts/inter-latin.woff2') format('woff2');
}
</style>

<!-- Tailwind CSS (local build) -->
<link rel="stylesheet" href="{{ rootPath }}css/tailwind.css">

<!-- Custom CSS -->
<link rel="stylesheet" href="{{ rootPath }}css/custom.css">

<!-- Structured Data: Organization -->
{% include "partials/structured-data-org.njk" %}
